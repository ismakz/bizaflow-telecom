# Copier vers .env.local (dev) ou renseigner dans Vercel → Settings → Environment Variables
# Ne jamais committer .env.local avec des secrets réels.

# ── Firebase (navigateur) — préfixe NEXT_PUBLIC_ obligatoire
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin (API routes serveur uniquement — pas de NEXT_PUBLIC)
# Clé JSON service account : private_key avec \n échappés sur une ligne
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ── Twilio (appels sortants réels — optionnel)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# URL publique HTTPS du site (webhooks Twilio), ex. https://votre-app.vercel.app
APP_BASE_URL=
VOICE_PROVIDER_REAL_ENABLED=false

# ── Voix côté client (simulation vs réel)
NEXT_PUBLIC_VOICE_PROVIDER_MODE=mock
NEXT_PUBLIC_VOICE_REAL_ENABLED=false

# Monitoring : GET /api/health (vérifie notamment la présence des clés Admin côté serveur)
