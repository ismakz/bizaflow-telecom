rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // HELPERS
    // =========================
    function isAuth() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/telecom_users/$(request.auth.uid)).data;
    }

    function myTelecomNumber() {
      return getUserData().telecomNumber;
    }

    function isCEO() {
      return isAuth() && getUserData().role == "ceo";
    }

    function isApproved() {
      return isAuth() && getUserData().status == "approved";
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isParticipant(participantIds) {
      return isApproved() && request.auth.uid in participantIds;
    }

    function hasTwoParticipants(participantIds) {
      return participantIds is list &&
        participantIds.size() == 2 &&
        participantIds[0] is string &&
        participantIds[1] is string;
    }

    function conversationIdMatches(conversationId, participantIds) {
      return hasTwoParticipants(participantIds) &&
        conversationId == participantIds[0] + "__" + participantIds[1];
    }

    function conversationDoc(conversationId) {
      return get(/databases/$(database)/documents/telecom_conversations/$(conversationId)).data;
    }

    function conversationExists(conversationId) {
      return exists(/databases/$(database)/documents/telecom_conversations/$(conversationId));
    }

    function uidInParticipants(listValue) {
      return listValue is list && request.auth.uid in listValue;
    }

    function numberInParticipants(listValue) {
      return listValue is list && myTelecomNumber() in listValue;
    }

    function messageConversationMatches(data) {
      return (
        conversationDoc(data.conversationId).participantIds is list &&
        conversationIdMatches(data.conversationId, conversationDoc(data.conversationId).participantIds) &&
        data.senderId in conversationDoc(data.conversationId).participantIds &&
        data.receiverId in conversationDoc(data.conversationId).participantIds
      ) || (
        conversationDoc(data.conversationId).participants is list &&
        data.senderId in conversationDoc(data.conversationId).participants &&
        data.receiverId in conversationDoc(data.conversationId).participants
      );
    }

    function groupDoc(groupId) {
      return get(/databases/$(database)/documents/telecom_groups/$(groupId)).data;
    }

    function groupExists(groupId) {
      return exists(/databases/$(database)/documents/telecom_groups/$(groupId));
    }

    function isGroupMember(groupId) {
      return groupExists(groupId) && request.auth.uid in groupDoc(groupId).memberIds;
    }

    function isGroupAdmin(groupId) {
      return isCEO() || (groupExists(groupId) && request.auth.uid in groupDoc(groupId).adminIds);
    }

    function isSafeSelfUserUpdate(uid) {
      return isOwner(uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "name",
          "mustChangePassword",
          "currentDocument",
          "lastSeen",
          "lastSeenAt",
          "isOnline",
          "updatedAt",
          "pushToken",
          "fcmToken"
        ]);
    }

    function isDirectorySafeWriteForApprovedUser(uid) {
      return isApproved() &&
        request.resource.data.uid == uid &&
        request.resource.data.telecomNumber is string &&
        request.resource.data.status == "approved" &&
        request.resource.data.isCallable == true &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "uid",
          "name",
          "telecomNumber",
          "status",
          "isCallable",
          "updatedAt"
        ]);
    }

    function isCallerOrReceiver(data) {
      return isApproved() && (
        data.callerId == request.auth.uid ||
        data.callerUserId == request.auth.uid ||
        data.receiverId == request.auth.uid ||
        data.receiverUserId == request.auth.uid ||
        data.targetUserId == request.auth.uid ||
        data.userId == request.auth.uid ||
        isCEO()
      );
    }

    function isTelecomCallParticipant(data) {
      return isApproved() && (
        isCEO() ||
        data.callerUserId == request.auth.uid ||
        data.receiverUserId == request.auth.uid ||
        data.targetUserId == request.auth.uid ||
        data.callerId == request.auth.uid ||
        data.receiverId == request.auth.uid ||
        data.userId == request.auth.uid ||
        data.from == myTelecomNumber() ||
        data.to == myTelecomNumber() ||
        data.callerTelecomNumber == myTelecomNumber() ||
        data.targetTelecomNumber == myTelecomNumber()
      );
    }

    function isTelecomCallCreator(data) {
      return isApproved() && (
        isCEO() ||
        data.callerUserId == request.auth.uid ||
        data.callerId == request.auth.uid ||
        data.userId == request.auth.uid ||
        data.from == myTelecomNumber() ||
        data.callerTelecomNumber == myTelecomNumber()
      );
    }

    function callDoc(callId) {
      return get(/databases/$(database)/documents/telecom_internal_calls/$(callId)).data;
    }

    function isCallParticipantById(callId) {
      return isApproved() && (
        isCEO() ||
        callDoc(callId).callerId == request.auth.uid ||
        callDoc(callId).callerUserId == request.auth.uid ||
        callDoc(callId).receiverId == request.auth.uid ||
        callDoc(callId).receiverUserId == request.auth.uid ||
        callDoc(callId).targetUserId == request.auth.uid
      );
    }

    function callerForCall(callId) {
      return callDoc(callId).callerId == request.auth.uid;
    }

    function receiverForCall(callId) {
      return callDoc(callId).receiverId == request.auth.uid ||
        callDoc(callId).receiverUserId == request.auth.uid ||
        callDoc(callId).targetUserId == request.auth.uid;
    }

    // =========================
    // USERS
    // =========================
    match /telecom_users/{uid} {
      allow read: if isOwner(uid) || isCEO() || (
        isApproved() && resource.data.status == "approved"
      );

      allow create: if isOwner(uid);
      allow update: if isSafeSelfUserUpdate(uid) || isCEO();
      allow delete: if isCEO();
    }

    // =========================
    // PRESENCE
    // =========================
    match /telecom_presence/{uid} {
      allow read: if isApproved();
      allow create, update: if isOwner(uid) && isApproved();
      allow delete: if isOwner(uid) || isCEO();
    }

    // =========================
    // PUBLIC DIRECTORY
    // =========================
    match /telecom_directory/{uid} {
      allow read: if isApproved();
      allow create: if isOwner(uid) || isCEO() || (
        isApproved()
        && request.resource.data.uid == uid
        && request.resource.data.status == "approved"
        && request.resource.data.isCallable == true
      );
      allow update: if isOwner(uid) || isCEO() || isDirectorySafeWriteForApprovedUser(uid);
      allow delete: if isCEO();
    }

    // =========================
    // CONFIG
    // Important: lecture pour users, écriture CEO seulement
    // =========================
    match /telecom_config/{doc} {
      allow read: if isApproved() || (isAuth() && doc == "counter");
      allow create: if isCEO() || (
        doc == "counter" &&
        isAuth() &&
        request.resource.data.keys().hasOnly(["lastNumber"]) &&
        request.resource.data.lastNumber is int &&
        request.resource.data.lastNumber >= 10001
      );
      allow update: if isCEO() || (
        doc == "counter" &&
        isAuth() &&
        resource.data.lastNumber is int &&
        request.resource.data.keys().hasOnly(["lastNumber"]) &&
        request.resource.data.lastNumber is int &&
        request.resource.data.lastNumber == resource.data.lastNumber + 1
      );
      allow delete: if isCEO();
    }

    match /telecom_internal_settings/{doc} {
      allow read: if isApproved();
      allow create: if isApproved() && doc == "default";
      allow update, delete: if isCEO();
    }

    // =========================
    // CONTACTS
    // =========================
    match /telecom_contacts/{uid}/contacts/{contactId} {
      allow read, write: if isOwner(uid) && isApproved();
    }

    // =========================
    // OLD / GENERAL CALLS
    // =========================
    match /telecom_calls/{callId} {
      allow read: if isTelecomCallParticipant(resource.data);

      allow create: if isTelecomCallCreator(request.resource.data);

      allow update: if isTelecomCallParticipant(resource.data);

      allow delete: if isCEO();
    }

    // =========================
    // INTERNAL CONVERSATIONS
    // =========================
    match /telecom_conversations/{conversationId} {
      allow read: if isCEO() || (
        isApproved() && (
          uidInParticipants(resource.data.participantIds) ||
          uidInParticipants(resource.data.participants) ||
          numberInParticipants(resource.data.participantNumbers)
        )
      );

      allow create: if (
          isApproved()
          && conversationIdMatches(conversationId, request.resource.data.participantIds)
          && request.auth.uid in request.resource.data.participantIds
        ) || (
          isApproved()
          && request.resource.data.type == "group"
          && request.resource.data.groupId is string
          && conversationId == request.resource.data.groupId
          && request.auth.uid in request.resource.data.participantIds
        );

      allow update: if isCEO() || (
        (
          uidInParticipants(resource.data.participantIds) ||
          uidInParticipants(resource.data.participants) ||
          numberInParticipants(resource.data.participantNumbers)
        )
        && (
          request.resource.data.participantIds == resource.data.participantIds ||
          request.resource.data.participants == resource.data.participants
        )
      ) || (
        isApproved()
        && resource.data.type == "group"
        && resource.data.groupId is string
        && isGroupAdmin(resource.data.groupId)
      );

      allow delete: if isCEO();
    }

    match /telecom_groups/{groupId} {
      allow read: if isApproved() && (
        isCEO() ||
        uidInParticipants(resource.data.memberIds)
      );

      allow create: if isApproved()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds
        && request.auth.uid in request.resource.data.adminIds;

      allow update: if isApproved() && isGroupAdmin(groupId);
      allow delete: if isApproved() && isGroupAdmin(groupId);
    }

    // =========================
    // INTERNAL MESSAGES
    // =========================
    match /telecom_messages/{messageId} {
      allow read: if isCEO() || (
        isApproved() &&
        (
          resource.data.senderId == request.auth.uid ||
          resource.data.receiverId == request.auth.uid ||
          resource.data.callerUserId == request.auth.uid ||
          resource.data.targetUserId == request.auth.uid ||
          resource.data.from == myTelecomNumber() ||
          resource.data.to == myTelecomNumber() ||
          uidInParticipants(resource.data.participantIds) ||
          numberInParticipants(resource.data.participantNumbers) ||
          uidInParticipants(resource.data.participants) ||
          (
            resource.data.conversationId is string &&
            conversationExists(resource.data.conversationId) &&
            (
              uidInParticipants(conversationDoc(resource.data.conversationId).participantIds) ||
              uidInParticipants(conversationDoc(resource.data.conversationId).participants) ||
              numberInParticipants(conversationDoc(resource.data.conversationId).participantNumbers)
            )
          )
        )
      );

      allow create: if isApproved()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 2000
        && request.resource.data.conversationId is string
        && (
          (
            request.resource.data.receiverId is string
            && request.resource.data.receiverId != request.auth.uid
            && messageConversationMatches(request.resource.data)
          ) || (
            request.resource.data.groupId is string
            && request.resource.data.conversationId == request.resource.data.groupId
            && isGroupMember(request.resource.data.groupId)
            && request.resource.data.type in ["text", "system"]
          )
        );

      allow update: if isCEO() || (
        isApproved()
        && (
          (
            resource.data.receiverId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "updatedAt", "deliveredAt", "readAt"])
            && request.resource.data.status in ["delivered", "read"]
          ) ||
          (
            resource.data.senderId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["body", "editedAt", "updatedAt"])
            && request.resource.data.body is string
            && request.resource.data.body.size() > 0
            && request.resource.data.body.size() <= 2000
          ) ||
          (
            (
              uidInParticipants(conversationDoc(resource.data.conversationId).participantIds) ||
              uidInParticipants(conversationDoc(resource.data.conversationId).participants)
            )
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["reactionsByUser", "updatedAt"])
          ) ||
          (
            (
              uidInParticipants(conversationDoc(resource.data.conversationId).participantIds) ||
              uidInParticipants(conversationDoc(resource.data.conversationId).participants)
            )
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["statusByUser", "updatedAt", "readAt", "deliveredAt", "status"])
          )
        )
      );

      allow delete: if isCEO();
    }

    match /telecom_statuses/{statusId} {
      allow read: if isApproved();

      allow create: if isApproved()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.type in ["text", "image"];

      allow update: if isApproved() && (
        resource.data.userId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["viewers", "updatedAt"])
      );

      allow delete: if isCEO() || (
        isApproved() &&
        resource.data.userId == request.auth.uid
      );
    }

    // =========================
    // INTERNAL CALLS
    // =========================
    match /telecom_internal_calls/{callId} {
      allow read: if isCallerOrReceiver(resource.data);

      allow create: if isApproved()
        && request.resource.data.callerId == request.auth.uid
        && request.resource.data.receiverId is string
        && request.resource.data.receiverId != request.auth.uid
        && hasTwoParticipants(request.resource.data.participants)
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.receiverId in request.resource.data.participants
        && request.resource.data.status == "ringing";

      allow update: if isApproved() && (
        isCEO() ||
        (
          resource.data.receiverId == request.auth.uid &&
          resource.data.status == "ringing" &&
          request.resource.data.status in ["accepted", "declined"] &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "answeredAt", "endedAt", "updatedAt"])
        ) ||
        (
          (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid) &&
          request.resource.data.status in ["completed", "failed", "missed"] &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "endedAt", "durationSeconds", "updatedAt"])
        )
      );

      allow delete: if isCEO();
    }

    // =========================
    // WEBRTC SIGNALS
    // =========================
    match /telecom_call_signals/{callId} {
      allow read: if isCallParticipantById(callId);

      allow create: if isApproved()
        && callerForCall(callId)
        && request.resource.data.callId == callId
        && request.resource.data.callerId == request.auth.uid
        && request.resource.data.receiverId == callDoc(callId).receiverId;

      allow update: if isCallParticipantById(callId) && (
        isCEO() ||
        (
          callerForCall(callId) &&
          request.resource.data.callId == resource.data.callId &&
          request.resource.data.callerId == resource.data.callerId &&
          request.resource.data.receiverId == resource.data.receiverId &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["callerOffer", "callerCandidates", "updatedAt"])
        ) ||
        (
          receiverForCall(callId) &&
          request.resource.data.callId == resource.data.callId &&
          request.resource.data.callerId == resource.data.callerId &&
          request.resource.data.receiverId == resource.data.receiverId &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["receiverAnswer", "receiverCandidates", "sessionReady", "updatedAt"])
        )
      );

      allow delete: if isCEO();
    }

    // =========================
    // PUSH TOKENS
    // =========================
    match /telecom_push_tokens/{tokenId} {
      allow read: if isApproved() && (
        isCEO() || resource.data.userId == request.auth.uid
      );

      allow create: if isApproved()
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if isApproved() && (
        isCEO() || resource.data.userId == request.auth.uid
      );
    }

    // =========================
    // TRANSACTIONS
    // =========================
    match /telecom_transactions/{txId} {
      allow read: if isApproved() && (
        resource.data.userId == request.auth.uid || isCEO()
      );

      allow create: if isApproved();
      allow update, delete: if isCEO();
    }

    // =========================
    // PACKS CATALOG
    // =========================
    match /telecom_packs/{packId} {
      allow read: if isApproved();
      allow create, update, delete: if isCEO();
    }

    // =========================
    // USER PACKS
    // =========================
    match /telecom_user_packs/{userPackId} {
      allow read: if isApproved() && (
        resource.data.userId == request.auth.uid || isCEO()
      );

      allow create: if isApproved() && (
        request.resource.data.userId == request.auth.uid || isCEO()
      );

      allow update, delete: if isCEO();
    }
  }
}
